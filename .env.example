POSTGRES_DB=volunteer_app
POSTGRES_USER=volunteer
POSTGRES_PASSWORD=volunteer
DATABASE_URL=postgresql://volunteer:volunteer@postgres:5432/volunteer_app?schema=public

JWT_SECRET=your-secret-key
CORS_ORIGIN=http://localhost,https://localhost

# Optional first admin bootstrap
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Traefik production profile (Let's Encrypt)
TRAEFIK_HOSTNAME=example.com
TRAEFIK_ACME_EMAIL=admin@example.com

AUTH_SERVICE_URL=http://auth-service:5001
PROJECTS_SERVICE_URL=http://projects-service:5002
APPLICATIONS_SERVICE_URL=http://applications-service:5003
ADMIN_SERVICE_URL=http://admin-service:5004
GATEWAY_URL=http://gateway:5000
